<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>PawStuff | Landing</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
		<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css"/>
		<script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
		<style>
			html {
				scroll-behavior: smooth;
			}

			:root {
				--page: #f4f5f9;
				--white: #ffffff;
				--ink: #171a21;
				--muted: #50555f;
				--blue: #154b7f;
				--blue-soft: #2f679d;
				--green: #2baf6f;
				--green-dark: #1f8a56;
				--blue-circle-x: 84%;
				--blue-circle-rx: 45%;
			}

			* {
				box-sizing: border-box;
			}

			body {
				margin: 0;
				min-height: 100%;
				overflow-x: hidden;
				font-family: 'Nunito', sans-serif;
				color: var(--ink);
				background: radial-gradient(800px 420px at 90% -10%, rgba(21, 75, 127, 0.16), transparent 70%), var(--page);
			}

			.wrap {
				width: 100%;
				margin: 0;
				padding: 0;
			}

			.banner {
				position: relative;
				height: 100vh;
				min-height: 100vh;
				overflow: hidden;
				background: var(--white);
			}

			.banner::before {
				content: "";
				position: absolute;
				inset: 0;
				background: linear-gradient(160deg, var(--blue), #1f5f9a 68%, #194c80);
				clip-path: ellipse(var(--blue-circle-rx) 98% at var(--blue-circle-x) 30%);
				z-index: 1;
			}

			.banner::after {
				content: "";
				position: absolute;
				inset: 0;
				background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.13), transparent 35%);
				z-index: 2;
				pointer-events: none;
			}

			.top-row,
			.hero-copy,
			.pet-shot,
			.cat-shot {
				position: relative;
				z-index: 3;
			}

			.top-row {
				display: flex;
				align-items: center;
				gap: 0.45rem;
				justify-content: flex-end;
				padding: 1.2rem 1.8rem 0 1.3rem;
				z-index: 5;
			}

			.logo {
				display: inline-flex;
				align-items: center;
				gap: 0;
				text-decoration: none;
				margin-right: auto;
			}

			.logo img {
				width: 88px;
				height: 88px;
				display: block;
				object-fit: contain;
				clip-path: inset(0 20px 0 0);
				margin-right: -14px;
			}

			.logo span {
				display: inline-flex;
				align-items: center;
				color: #184a79;
				font-family: 'Montserrat', sans-serif;
				font-weight: 800;
				font-size: 1.18rem;
				letter-spacing: -0.01em;
				line-height: 1.1;
				margin-left: -7px;
			}

			.nav-links {
				display: inline-flex;
				gap: 0.28rem;
				align-items: center;
				border-radius: 999px;
				padding: 0.3rem;
				background: linear-gradient(120deg, rgba(23, 73, 120, 0.92), rgba(39, 101, 157, 0.9));
				backdrop-filter: blur(8px);
				border: 1px solid rgba(255, 255, 255, 0.18);
				box-shadow: 0 10px 22px rgba(8, 23, 40, 0.18);
			}

			.nav-links a {
				text-decoration: none;
				color: #f7fbff;
				font-family: 'Montserrat', sans-serif;
				font-size: 0.74rem;
				font-weight: 700;
				letter-spacing: 0.03em;
				padding: 0.45rem 0.66rem;
				border-radius: 999px;
				text-transform: uppercase;
				white-space: nowrap;
				text-shadow: 0 1px 1px rgba(0, 0, 0, 0.2);
			}

			.nav-links a:hover {
				background: rgba(255, 255, 255, 0.22);
			}

			.signup {
				text-decoration: none;
				background: #ffffff;
				color: #11395f;
				border-radius: 999px;
				padding: 0.48rem 1rem;
				font-family: 'Montserrat', sans-serif;
				font-size: 0.72rem;
				font-weight: 800;
				letter-spacing: 0.03em;
				text-transform: uppercase;
				white-space: nowrap;
				margin-left: 0.2rem;
			}

			.hero-copy {
				position: absolute;
				top: 9.6rem;
				left: clamp(2rem, 5vw, 4rem);
				width: min(40%, 460px);
				margin: 0;
				padding: 0;
			}

			.hero-copy small {
				display: inline-block;
				color: #1a4d80;
				font-family: 'Montserrat', sans-serif;
				font-weight: 700;
				letter-spacing: 0.01em;
			}

			.hero-copy h1 {
				margin: 0.3rem 0 0;
				font-family: 'Montserrat', sans-serif;
				font-size: clamp(1.85rem, 3.5vw, 2.9rem);
				line-height: 0.96;
				letter-spacing: -0.03em;
				color: #171a21;
			}

			.hero-copy p {
				margin: 0.8rem 0 0;
				color: var(--muted);
				line-height: 1.6;
				max-width: 47ch;
				font-size: 0.95rem;
			}

			.learn {
				margin-top: 0.95rem;
				display: inline-block;
				text-decoration: none;
				border-radius: 999px;
				padding: 0.56rem 1.05rem;
				font-family: 'Montserrat', sans-serif;
				font-size: 0.72rem;
				font-weight: 800;
				color: #fff;
				text-transform: uppercase;
				letter-spacing: 0.03em;
				background: linear-gradient(130deg, var(--green), var(--green-dark));
			}

			.pet-shot {
				position: absolute;
				right: 0;
				bottom: 0;
				width: min(46vw, 560px);
				aspect-ratio: 4 / 5;
				border-radius: 0;
				overflow: hidden;
				border: 0;
				box-shadow: none;
				background: transparent;
				margin: 0;
				pointer-events: none;
				z-index: 2;
			}

			.pet-shot img {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: contain;
				object-position: right bottom;
				filter: drop-shadow(0 16px 24px rgba(8, 20, 36, 0.35));
				margin: 0;
			}

			.cat-shot {
				position: absolute;
				left: clamp(2rem, 5vw, 4rem);
				bottom: 0;
				width: min(42vw, 400px);
				aspect-ratio: 3 / 4;
				border-radius: 0;
				overflow: hidden;
				border: 0;
				box-shadow: none;
				background: transparent;
				margin: 0;
				pointer-events: none;
				z-index: 2;
			}

			.cat-shot img {
				width: 100%;
				height: 100%;
				display: block;
				object-fit: contain;
				object-position: center bottom;
				filter: drop-shadow(0 12px 20px rgba(8, 20, 36, 0.25));
				margin: 0;
			}

			.products-container {
				max-width: 1400px;
				margin: 0 auto;
				padding: 0 2rem;
			}

			.swiper-slide {
				height: auto; /* Ensures all cards are same height */
				padding-bottom: 20px;
			}

			.product-card {
				background: #fff;
				border-radius: 16px;
				box-shadow: 0 4px 15px rgba(21, 75, 127, 0.08);
				padding: 1.5rem;
				display: flex;
				flex-direction: column;
				align-items: center;
				transition: transform 0.3s ease;
				border: 1px solid rgba(0, 0, 0, 0.03);
			}

			.product-card:hover {
				transform: translateY(-5px);
			}

			.product-rating {
				display: flex;
				align-items: center;
				gap: 0.35rem;
				margin: 0.15rem 0 1rem;
			}

			.product-rating .star {
				color: #c9d3de;
				font-size: 0.9rem;
				line-height: 1;
			}

			.product-rating .star.filled {
				color: #f4b740;
			}

			.product-rating .rating-text {
				color: var(--muted);
				font-size: 0.82rem;
				font-weight: 600;
			}

			.nav-btn {
				width: 40px;
				height: 40px;
				background: #171a21;
				color: white;
				border-radius: 50%;
				display: flex;
				align-items: center;
				justify-content: center;
				cursor: pointer;
				transition: background 0.3s;
				user-select: none;
			}

			.nav-btn:hover {
				background: var(--blue);
			}
			.nav-btn.swiper-button-disabled {
				opacity: 0.3;
				cursor: auto;
			}

			@media(max-width: 900px) {
				.top-row {
					flex-wrap: wrap;
					justify-content: flex-start;
					gap: 0.6rem;
				}

				.nav-links {
					order: 3;
					width: 100%;
					justify-content: center;
				}

				.hero-copy {
					width: min(52%, 420px);
					top: 8.4rem;
				}
			}

			@media(max-width: 760px) {
				.banner {
					min-height: auto;
					height: auto;
					padding-bottom: 1rem;
				}

				.banner::before {
					clip-path: ellipse(145% 66% at 76% 4%);
				}

				.top-row {
					padding: 0.8rem 0.8rem 0;
					justify-content: space-between;
					align-items: center;
					row-gap: 0.6rem;
				}

				.logo img {
					width: 70px;
					height: 70px;
					margin-right: -10px;
				}

				.logo span {
					font-size: 1rem;
					margin-left: -4px;
				}

				.nav-links {
					gap: 0.24rem;
					padding: 0.22rem;
					overflow-x: auto;
					justify-content: flex-start;
					-webkit-overflow-scrolling: touch;
					scrollbar-width: none;
				}

				.nav-links::-webkit-scrollbar {
					display: none;
				}

				.nav-links a {
					font-size: 0.66rem;
					padding: 0.4rem 0.56rem;
					flex: 0 0 auto;
				}

				.signup {
					padding: 0.4rem 0.75rem;
					font-size: 0.64rem;
				}

				.hero-copy {
					position: static;
					width: auto;
					margin: 0.7rem 1rem 0;
					text-align: left;
				}

				.hero-copy h1 {
					font-size: clamp(1.8rem, 8vw, 2.4rem);
					line-height: 1.06;
				}

				.hero-copy p {
					font-size: 0.88rem;
					margin-top: 0.6rem;
				}

				.learn {
					margin-top: 0.7rem;
				}

				.pet-shot {
					position: static;
					width: min(80vw, 320px);
					margin: 0.1rem auto 0;
					aspect-ratio: 4 / 3;
				}

				.cat-shot {
					position: static;
					width: min(62vw, 200px);
					height: auto;
					margin: 0 auto;
				}

				#about {
					min-height: auto !important;
					padding: 2.2rem 1rem !important;
				}

				#about > div {
					grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
					gap: 0.9rem !important;
					margin-bottom: 1.5rem !important;
				}

				#products {
					padding: 2.2rem 0 !important;
				}

				.products-container {
					padding: 0 1rem !important;
				}

				#gallery {
					padding: 2.2rem 1rem !important;
					overflow-x: hidden !important;
				}

				#gallery > div > div {
					min-width: 0 !important;
					grid-template-columns: repeat(2, minmax(0, 1fr)) !important;
					gap: 0.8rem !important;
				}

				#why-choose-us {
					padding: 2.4rem 1rem !important;
				}

				section[aria-label="Customer Testimonials"] {
					margin: 2rem 1rem 0 !important;
					padding: 1.2rem !important;
					overflow-x: hidden !important;
				}

				section[aria-label="Customer Testimonials"] > div > div:last-child {
					min-width: 0 !important;
					grid-template-columns: 1fr !important;
				}
			}

			@media(max-width: 520px) {
				.top-row {
					padding: 0.65rem 0.65rem 0;
				}

				.hero-copy h1 {
					font-size: clamp(1.5rem, 7.6vw, 2rem);
				}

				#about > div,
				#gallery > div > div {
					grid-template-columns: 1fr !important;
				}

				#why-choose-us > div:last-child {
					grid-template-columns: 1fr !important;
					gap: 1.3rem !important;
				}

				#why-choose-us > div:last-child > div:first-child > div:last-child {
					position: static !important;
					margin-top: 0.8rem !important;
					width: 100% !important;
				}
			}
		</style>
	</head>
	<body>
		<main class="wrap">
			<section class="banner" id="home" aria-label="Banner">
				<div class="top-row">
					<a href="{{ path('app_landing') }}" class="logo" aria-label="PawStuff home">
						<img src="{{ asset('images/logo.png') }}" alt="PawStuff logo">
						<span>PawStuff</span>
					</a>

					<nav class="nav-links" aria-label="Main links">
						<a href="{{ path('app_landing') }}#home">Home</a>
						<a href="{{ path('app_landing') }}#about">About Us</a>
						<a href="{{ path('app_landing') }}#products">Products</a>
						<a href="{{ path('app_landing') }}#gallery">Gallery</a>
						<a href="{{ path('app_landing') }}#why-choose-us">Why Choose Us</a>
						<a href="{{ path('app_contact') }}">Contact Us</a>
					</nav>

					<a href="{{ path('app_register') }}" class="signup">Sign Up</a>
				</div>

				<article class="hero-copy">
					<small>At PawStuff</small>
					<h1>We make pet care simple. Quality supplies, happy pets, wagging tails.</h1>
					<p>
						We believe every pet deserves the best. From premium nutrition to playful toys and cozy essentials, we carefully curate products that keep tails wagging and purrs coming.
					</p>
					<a class="learn" href="{{ path('app_login') }}">Shop Now</a>
				</article>

				<figure class="pet-shot" aria-label="Featured dog image">
					<img src="{{ asset('images/ddog2-removebg-preview.png') }}" alt="Dog">
				</figure>

				<figure class="cat-shot" aria-label="Featured cat image">
					<img src="{{ asset('images/cat1-removebg-preview.png') }}" alt="Cat">
				</figure>
			</section>

			<section id="about" style="background: linear-gradient(160deg, #154b7f, #2f679d 68%, #17547f); padding: 3.5rem 2rem; text-align: center; min-height: 100vh; display: flex; flex-direction: column; justify-content: center; align-items: center;">
				<h2 style="font-family: 'Montserrat', sans-serif; font-size: clamp(2.2rem, 5vw, 3.2rem); font-weight: 900; color: #ffffff; margin: 0 0 1rem; letter-spacing: -0.02em; line-height: 1.1;">Meet Our Team</h2>
				<p style="color: #e8f0f8; max-width: 850px; margin: 0 auto 2.5rem; font-size: 1.05rem; line-height: 1.6;">Our passionate team is dedicated to delivering the best products and service for pet owners everywhere. We believe in quality, care, and making pets happy.</p>

				<div style="display: grid; grid-template-columns: repeat(4, minmax(0, 1fr)); gap: 2rem; max-width: 1200px; margin: 0 auto 3rem; width: 100%;">
					<div style="background: #ffffff; border-radius: 16px; padding: 1.5rem; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s;">
						<div style="width: 100%; aspect-ratio: 1; overflow: hidden; border-radius: 12px; background: #f0f4f9; margin-bottom: 1.2rem; display: flex; align-items: center; justify-content: center;">
							<img src="{{ asset('images/KhriciaDivino.jpg') }}" alt="Khricia Divino" style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
						</div>
						<h3 style="font-family: 'Montserrat', sans-serif; font-size: 1.15rem; font-weight: 700; color: #154b7f; margin: 0 0 0.4rem; letter-spacing: -0.01em;">Khricia Divino</h3>
						<p style="color: #50555f; font-size: 0.9rem; font-weight: 500; margin: 0;">Founder & CEO</p>
					</div>

					<div style="background: #ffffff; border-radius: 16px; padding: 1.5rem; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s;">
						<div style="width: 100%; aspect-ratio: 1; overflow: hidden; border-radius: 12px; background: #f0f4f9; margin-bottom: 1.2rem; display: flex; align-items: center; justify-content: center;">
							<img src="{{ asset('images/Jim.jpg') }}" alt="Jimwella De Guzman" style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
						</div>
						<h3 style="font-family: 'Montserrat', sans-serif; font-size: 1.15rem; font-weight: 700; color: #154b7f; margin: 0 0 0.4rem; letter-spacing: -0.01em;">Jimwella De Guzman</h3>
						<p style="color: #50555f; font-size: 0.9rem; font-weight: 500; margin: 0;">Product Director</p>
					</div>

					<div style="background: #ffffff; border-radius: 16px; padding: 1.5rem; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s;">
						<div style="width: 100%; aspect-ratio: 1; overflow: hidden; border-radius: 12px; background: #f0f4f9; margin-bottom: 1.2rem; display: flex; align-items: center; justify-content: center;">
							<img src="{{ asset('images/Rhea.png') }}" alt="Rhea Amor Delejero" style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
						</div>
						<h3 style="font-family: 'Montserrat', sans-serif; font-size: 1.15rem; font-weight: 700; color: #154b7f; margin: 0 0 0.4rem; letter-spacing: -0.01em;">Rhea Amor Delejero</h3>
						<p style="color: #50555f; font-size: 0.9rem; font-weight: 500; margin: 0;">Customer Success Lead</p>
					</div>

					<div style="background: #ffffff; border-radius: 16px; padding: 1.5rem; overflow: hidden; transition: transform 0.3s, box-shadow 0.3s;">
						<div style="width: 100%; aspect-ratio: 1; overflow: hidden; border-radius: 12px; background: #f0f4f9; margin-bottom: 1.2rem; display: flex; align-items: center; justify-content: center;">
							<img src="{{ asset('images/vincent.png') }}" alt="Vincent Delostrico" style="width: 100%; height: 100%; object-fit: cover; object-position: center;">
						</div>
						<h3 style="font-family: 'Montserrat', sans-serif; font-size: 1.15rem; font-weight: 700; color: #154b7f; margin: 0 0 0.4rem; letter-spacing: -0.01em;">Vincent Delostrico</h3>
						<p style="color: #50555f; font-size: 0.9rem; font-weight: 500; margin: 0;">Operations Manager</p>
					</div>
				</div>

				<a href="{{ path('app_about') }}" style="background: #ffffff; color: #154b7f; font-family: 'Montserrat', sans-serif; font-weight: 700; font-size: 1rem; padding: 1rem 2.5rem; border-radius: 50px; text-decoration: none; display: inline-block; transition: all 0.3s ease; box-shadow: 0 4px 15px rgba(0,0,0,0.1);">
					Learn More About Us
				</a>
			</section>
			<section id="products" style="padding: 5rem 0; background: var(--white); position: relative;">
<div class="products-container">
	<div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2.5rem;">
		<h2 style="margin: 0; font-family: 'Montserrat', sans-serif; font-size: 2.2rem; font-weight: 800; color: var(--blue);">Browse Products</h2>

		<div style="display: flex; gap: 12px;">
			<div class="nav-btn prev-btn">❮</div>
			<div class="nav-btn next-btn">❯</div>
		</div>
	</div>

	<div class="swiper productSwiper">
		<div class="swiper-wrapper">
			{% set items = [
					{'name': "Charlie's Choice", 'img': 'Charlie-s-Choice-69c01614331a4.jpg', 'price': '150.00', 'desc': '72% salmon content', 'rating': 4.8, 'reviews': 148},
					{'name': 'Carriers', 'img': 'aesthetic-cage-69c0211ba9536.jpg', 'price': '699.00', 'desc': 'Hard-sided travel', 'rating': 4.6, 'reviews': 92},
					{'name': 'Grooming Set', 'img': 'AllPetSolutions-4-Piece-Dog-Grooming-Set-69c0202724f1d.jpg', 'price': '200.00', 'desc': '4-piece kit', 'rating': 4.7, 'reviews': 75},
					{'name': 'Dental Chews', 'img': 'Bark-Bright-69c01f8975e9c.jpg', 'price': '199.00', 'desc': 'Chicken-based', 'rating': 4.9, 'reviews': 164},
					{'name': 'Harness Set', 'img': 'Blue-dog-harness-69c0208b5c230.jpg', 'price': '500.00', 'desc': 'Walking kit', 'rating': 4.5, 'reviews': 66},
					{'name': 'Pet Wipes', 'img': 'pet-wipes-69c03c6755705.jpg', 'price': '50.00', 'desc': 'Gentle cleaning', 'rating': 4.4, 'reviews': 58},
					{'name': 'Salmon Dry Food', 'img': 'Loveabowl-Salmon-Dry-Cat-Food-69c03c1984b88.jpg', 'price': '99.00', 'desc': 'Grain-free', 'rating': 4.8, 'reviews': 139},
					{'name': 'Shower Cup', 'img': 'Pet-Feet-Shower-Cup-69c03cdff0f0a.jpg', 'price': '144.00', 'desc': 'Paw cleaner', 'rating': 4.3, 'reviews': 44}
				] %}

			{% for item in items %}
				{% set colorKey = loop.index0 % 2 %}
				{% if colorKey == 0 %}
					{% set cardBg = '#87d3f8' %}
				{% elseif colorKey == 1 %}
					{% set cardBg = '#ffffff' %}
				{% endif %}

				<div class="swiper-slide">
					<div class="product-card" style="background: {{ cardBg }};">
						<img src="{{ asset('images/' ~ item.img) }}" alt="{{ item.name }}" style="width: 130px; height: 130px; object-fit: contain; margin-bottom: 1rem;">
						<h3 style="font-family: 'Montserrat', sans-serif; font-size: 1.1rem; color: var(--blue); margin: 0 0 0.5rem;">{{ item.name }}</h3>
