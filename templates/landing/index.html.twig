<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PawStuff | Landing</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
    <style>
        html {
            scroll-behavior: smooth;
        }

        :root {
            --page: #f4f5f9;
            --white: #ffffff;
            --ink: #171a21;
            --muted: #50555f;
            --blue: #154b7f;
            --blue-soft: #2f679d;
            --green: #2baf6f;
            --green-dark: #1f8a56;
            --blue-circle-x: 84%;
            --blue-circle-rx: 45%;
        }

        * {
            box-sizing: border-box;
        }

        body {
            margin: 0;
            min-height: 100%;
            overflow-x: hidden;
            font-family: 'Nunito', sans-serif;
            color: var(--ink);
            background:
                radial-gradient(800px 420px at 90% -10%, rgba(21, 75, 127, 0.16), transparent 70%),
                var(--page);
        }

        .wrap {
            width: 100%;
            margin: 0;
            padding: 0;
        }

        .banner {
            position: relative;
            height: 100vh;
            min-height: 100vh;
            overflow: hidden;
            background: var(--white);
        }

        .banner::before {
            content: "";
            position: absolute;
            inset: 0;
            background: linear-gradient(160deg, var(--blue), #1f5f9a 68%, #194c80);
            clip-path: ellipse(var(--blue-circle-rx) 98% at var(--blue-circle-x) 30%);
            z-index: 1;
        }

        .banner::after {
            content: "";
            position: absolute;
            inset: 0;
            background: radial-gradient(circle at 50% 50%, rgba(255, 255, 255, 0.13), transparent 35%);
            z-index: 2;
            pointer-events: none;
        }

        .top-row,
        .hero-copy,
        .pet-shot,
        .cat-shot {
            position: relative;
            z-index: 3;
        }

        .top-row {
            display: flex;
            align-items: center;
            gap: 0.45rem;
            justify-content: flex-end;
            padding: 1.2rem 1.8rem 0 1.3rem;
            z-index: 5;
        }

        .logo {
            display: inline-flex;
            align-items: center;
            gap: 0;
            text-decoration: none;
            margin-right: auto;
        }

        .logo img {
            width: 88px;
            height: 88px;
            display: block;
            object-fit: contain;
            clip-path: inset(0 20px 0 0);
            margin-right: -14px;
        }

        .logo span {
            display: inline-flex;
            align-items: center;
            color: #184a79;
            font-family: 'Montserrat', sans-serif;
            font-weight: 800;
            font-size: 1.18rem;
            letter-spacing: -0.01em;
            line-height: 1.1;
            margin-left: -7px;
        }

        .nav-links {
            display: inline-flex;
            gap: 0.28rem;
            align-items: center;
            border-radius: 999px;
            padding: 0.3rem;
            background: rgba(255, 255, 255, 0.12);
            backdrop-filter: blur(5px);
        }

        .nav-links a {
            text-decoration: none;
            color: #f2f6ff;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.74rem;
            font-weight: 700;
            letter-spacing: 0.03em;
            padding: 0.45rem 0.66rem;
            border-radius: 999px;
            text-transform: uppercase;
            white-space: nowrap;
        }

        .nav-links a:hover {
            background: rgba(255, 255, 255, 0.15);
        }

        .signup {
            text-decoration: none;
            background: #ffffff;
            color: #11395f;
            border-radius: 999px;
            padding: 0.48rem 1rem;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.72rem;
            font-weight: 800;
            letter-spacing: 0.03em;
            text-transform: uppercase;
            white-space: nowrap;
            margin-left: 0.2rem;
        }

        .hero-copy {
            position: absolute;
            top: 9.6rem;
            left: clamp(2rem, 5vw, 4rem);
            width: min(40%, 460px);
            margin: 0;
            padding: 0;
        }

        .hero-copy small {
            display: inline-block;
            color: #1a4d80;
            font-family: 'Montserrat', sans-serif;
            font-weight: 700;
            letter-spacing: 0.01em;
        }

        .hero-copy h1 {
            margin: 0.3rem 0 0;
            font-family: 'Montserrat', sans-serif;
            font-size: clamp(1.85rem, 3.5vw, 2.9rem);
            line-height: 0.96;
            letter-spacing: -0.03em;
            color: #171a21;
        }

        .hero-copy p {
            margin: 0.8rem 0 0;
            color: var(--muted);
            line-height: 1.6;
            max-width: 47ch;
            font-size: 0.95rem;
        }

        .learn {
            margin-top: 0.95rem;
            display: inline-block;
            text-decoration: none;
            border-radius: 999px;
            padding: 0.56rem 1.05rem;
            font-family: 'Montserrat', sans-serif;
            font-size: 0.72rem;
            font-weight: 800;
            color: #fff;
            text-transform: uppercase;
            letter-spacing: 0.03em;
            background: linear-gradient(130deg, var(--green), var(--green-dark));
        }

        .pet-shot {
            position: absolute;
            right: 0;
            bottom: 0;
            width: min(46vw, 560px);
            aspect-ratio: 4 / 5;
            border-radius: 0;
            overflow: hidden;
            border: 0;
            box-shadow: none;
            background: transparent;
            margin: 0;
            pointer-events: none;
            z-index: 2;
        }

        .pet-shot img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
            object-position: right bottom;
            filter: drop-shadow(0 16px 24px rgba(8, 20, 36, 0.35));
            margin: 0;
        }

        .cat-shot {
            position: absolute;
            left: clamp(2rem, 5vw, 4rem);
            bottom: 0;
            width: min(42vw, 400px);
            aspect-ratio: 3 / 4;
            border-radius: 0;
            overflow: hidden;
            border: 0;
            box-shadow: none;
            background: transparent;
            margin: 0;
            pointer-events: none;
            z-index: 2;
        }

        .cat-shot img {
            width: 100%;
            height: 100%;
            display: block;
            object-fit: contain;
            object-position: center bottom;
            filter: drop-shadow(0 12px 20px rgba(8, 20, 36, 0.25));
            margin: 0;
        }

        @media (max-width: 900px) {
            .top-row {
                flex-wrap: wrap;
                justify-content: flex-start;
                gap: 0.6rem;
            }

            .nav-links {
                order: 3;
                width: 100%;
                justify-content: center;
            }

            .hero-copy {
                width: min(52%, 420px);
                top: 8.4rem;
            }
        }

        @media (max-width: 760px) {
            .banner {
                min-height: auto;
                height: auto;
                padding-bottom: 1rem;
            }

            .banner::before {
                clip-path: ellipse(130% 54% at 78% 0%);
            }

            .top-row {
                padding: 0.8rem 0.8rem 0;
            }

            .logo img {
                width: 70px;
                height: 70px;
                margin-right: -10px;
            }

            .logo span {
                font-size: 1rem;
                margin-left: -4px;
            }

            .nav-links {
                gap: 0.2rem;
                padding: 0.2rem;
            }

            .nav-links a {
                font-size: 0.62rem;
                padding: 0.35rem 0.5rem;
            }

            .signup {
                padding: 0.4rem 0.75rem;
                font-size: 0.64rem;
            }

            .hero-copy {
                position: static;
                width: auto;
                margin: 1.1rem 1rem 0;
            }

            .hero-copy h1 {
                font-size: clamp(1.8rem, 8vw, 2.4rem);
            }

            .hero-copy p {
                font-size: 0.9rem;
            }

            .pet-shot {
                position: static;
                width: min(92vw, 420px);
                margin: 0 auto;
                aspect-ratio: 4 / 3;
            }

            .cat-shot {
                position: static;
                width: min(320px, calc(100% - 2rem));
                height: auto;
                margin: 0.7rem auto 0;
            }
        }
    </style>
</head>
