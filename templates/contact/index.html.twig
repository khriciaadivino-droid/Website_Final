<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>Contact Us | PawStuff</title>
		<link rel="icon" type="image/png" href="{{ asset('images/logo.png') }}">
		<link rel="shortcut icon" href="{{ asset('images/logo.png') }}">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
		<style>:root
		{
			--page: #eef2f7;
			--paper: #ffffff;
			--ink: #171a21;
			--muted: #5c6370;
			--line: #d7deea;
			--blue: #154b7f;
			--blue-soft: #2f679d;
			--ok-bg: #d9f3e7;
			--ok-fg: #136f51;
			--err-bg: #fee2e2;
			--err-fg: #991b1b;
		}

		* {
			box-sizing: border-box;
		}

		html,
		body {
			margin: 0;
			min-height: 100%;
			font-family: 'Nunito', sans-serif;
			color: var(--ink);
			background: radial-gradient(circle at 15% -10%, #d9e8f9 0%, #eef2f7 46%) no-repeat;
		}

		.topbar {
			background: var(--paper);
			border-bottom: 1px solid var(--line);
			padding: 0.8rem 1.2rem;
		}

		.topbar-inner {
			max-width: 1160px;
			margin: 0 auto;
			display: flex;
			align-items: center;
			gap: 1rem;
		}

		.logo {
			margin-right: auto;
			display: inline-flex;
			align-items: center;
			gap: 0.4rem;
			text-decoration: none;
		}

		.logo img {
			height: 40px;
		}

		.logo span {
			font-family: 'Montserrat', sans-serif;
			font-weight: 800;
			font-size: 0.95rem;
			color: var(--ink);
		}

		.topbar nav {
			display: flex;
			gap: 0.25rem;
			flex-wrap: wrap;
			justify-content: flex-end;
		}

		.topbar nav a {
			text-decoration: none;
			color: var(--muted);
			font-family: 'Montserrat', sans-serif;
			font-size: 0.8rem;
			font-weight: 600;
			padding: 0.4rem 0.6rem;
			border-radius: 6px;
		}

		.topbar nav a:hover {
			color: var(--blue);
			background: #edf4fd;
		}

		.page {
			max-width: 1160px;
			margin: 0 auto;
			padding: clamp(1rem, 1.8vw, 1.4rem);
		}

		.shell {
			background: var(--paper);
			border: 1px solid var(--line);
			border-radius: 18px;
			box-shadow: 0 18px 36px rgba(11, 22, 41, 0.08);
			overflow: hidden;
		}

		.heading {
			padding: 1rem 1.3rem;
			border-bottom: 1px solid var(--line);
			background: linear-gradient(135deg, #f8fbff 0%, #f1f7ff 100%);
		}

		.heading small {
			font-family: 'Montserrat', sans-serif;
			color: var(--blue);
			font-weight: 700;
			font-size: 0.75rem;
			letter-spacing: 0.08em;
		}

		.heading h1 {
			margin: 0.35rem 0 0;
			font-family: 'Montserrat', sans-serif;
			font-weight: 800;
			font-size: clamp(1.25rem, 2vw, 1.65rem);
			letter-spacing: -0.02em;
		}

		.content {
			display: grid;
			grid-template-columns: 0.95fr 1.15fr;
			min-height: min(72vh, 700px);
		}

		.panel {
			padding: 1.2rem;
		}

		.panel + .panel {
			border-left: 1px solid var(--line);
		}

		.info-card {
			border: 1px solid var(--line);
			border-radius: 12px;
			padding: 0.9rem;
			margin-bottom: 0.7rem;
			background: #fbfdff;
		}

		.info-card h3 {
			margin: 0 0 0.2rem;
			font-family: 'Montserrat', sans-serif;
			font-size: 0.88rem;
			color: var(--blue);
		}

		.info-card p,
		.info-card a {
			margin: 0;
			color: var(--muted);
			font-size: 0.9rem;
			text-decoration: none;
		}

		.form-head {
			margin-bottom: 0.8rem;
		}

		.form-head h2 {
			margin: 0;
			font-family: 'Montserrat', sans-serif;
			font-size: 1rem;
			font-weight: 800;
		}

		.form-head p {
			margin: 0.35rem 0 0;
			color: var(--muted);
			font-size: 0.82rem;
		}

		.form-message {
			padding: 0.6rem 0.75rem;
			border-radius: 8px;
			margin-bottom: 0.8rem;
			display: none;
			font-size: 0.84rem;
		}

		.form-message.success {
			background: var(--ok-bg);
			color: var(--ok-fg);
			display: block;
		}

		.form-message.error {
			background: var(--err-bg);
			color: var(--err-fg);
			display: block;
		}

		form {
			display: grid;
			gap: 0.7rem;
		}

		.row {
			display: grid;
			grid-template-columns: 1fr 1fr;
			gap: 0.7rem;
		}

		.form-group {
			margin: 0;
		}

		.form-group label {
			display: block;
			margin-bottom: 0.28rem;
			font-family: 'Montserrat', sans-serif;
			font-weight: 600;
			font-size: 0.76rem;
			color: #252a35;
		}

		.form-group input,
		.form-group textarea {
			width: 100%;
			border: 1px solid #cdd7e5;
			border-radius: 8px;
			background: #ffffff;
			color: var(--ink);
			font-family: 'Nunito', sans-serif;
			font-size: 0.92rem;
			padding: 0.62rem 0.68rem;
			transition: border-color 0.2s, box-shadow 0.2s;
		}

		.form-group input:focus,
		.form-group textarea:focus {
			outline: none;
			border-color: var(--blue-soft);
			box-shadow: 0 0 0 2px rgba(47, 103, 157, 0.14);
		}

		.form-group textarea {
			min-height: 86px;
			resize: none;
		}

		.submit-btn {
			margin-top: 0.2rem;
			border: 0;
			border-radius: 9px;
			background: linear-gradient(135deg, #0f3f6c 0%, #20639e 100%);
			color: #ffffff;
			font-family: 'Montserrat', sans-serif;
			font-size: 0.9rem;
			font-weight: 700;
			padding: 0.72rem 0.9rem;
			cursor: pointer;
		}

		.submit-btn:hover {
			filter: brightness(1.04);
		}

		@media(max-width: 980px) {
			.content {
				grid-template-columns: 1fr;
				min-height: auto;
			}

			.panel + .panel {
				border-left: 0;
				border-top: 1px solid var(--line);
			}
		}

		@media(max-width: 660px) {
			.topbar nav {
				display: none;
			}

			.row {
				grid-template-columns: 1fr;
			}

			.page {
				padding: 0.7rem;
			}
		}
	</style>
</head>
<body>
	<header class="topbar">
		<div class="topbar-inner">
			<a href="{{ path('app_landing') }}" class="logo" aria-label="PawStuff home">
				<img src="{{ asset('images/logo.png') }}" alt="PawStuff logo">
				<span>PawStuff</span>
			</a>

			<nav aria-label="Main links">
				<a href="{{ path('app_landing') }}#home">Home</a>
				<a href="{{ path('app_landing') }}#about">About</a>
				<a href="{{ path('app_landing') }}#products">Products</a>
				<a href="{{ path('app_landing') }}#gallery">Gallery</a>
				<a href="{{ path('app_contact') }}">Contact</a>
			</nav>
		</div>
	</header>

	<main class="page">
		<section class="shell">
			<div class="heading">
				<small>CONTACT</small>
				<h1>Tell us what you need</h1>
			</div>

			<div class="content">
				<aside class="panel">
					<div class="info-card">
						<h3>Email</h3>
						<p>
							<a href="mailto:support@pawstuff.com">support@pawstuff.com</a>
						</p>
					</div>

					<div class="info-card">
						<h3>Phone</h3>
						<p>
							<a href="tel:+15551234567">+1 (555) 123-4567</a>
						</p>
					</div>

					<div class="info-card">
						<h3>Office</h3>
						<p>123 Pet Lane, San Francisco, CA 94105</p>
					</div>

					<div class="info-card">
						<h3>Response</h3>
						<p>Average response time is within 24 hours.</p>
					</div>
				</aside>

				<section class="panel">
					<div class="form-head">
						<h2>Send a message</h2>
					</div>

					<div class="form-message success" id="successMessage" role="status" aria-live="polite"></div>

					<div class="form-message error" id="errorMessage" role="alert" aria-live="assertive"></div>

					<form id="contactForm" method="POST" action="{{ path('app_contact_submit') }}">
						<div class="row">
							<div class="form-group">
								<label for="name">Full Name</label>
								<input type="text" id="name" name="name" required placeholder="John Doe" aria-required="true">
							</div>

							<div class="form-group">
								<label for="email">Email Address</label>
								<input type="email" id="email" name="email" required placeholder="john@example.com" aria-required="true">
							</div>
						</div>

						<div class="row">
							<div class="form-group">
								<label for="phone">Phone Number</label>
								<input type="tel" id="phone" name="phone" placeholder="+1 (555) 123-4567">
							</div>

							<div class="form-group">
								<label for="subject">Subject</label>
								<input type="text" id="subject" name="subject" required placeholder="How can we help?" aria-required="true">
							</div>
						</div>

						<div class="form-group">
							<label for="message">Message</label>
							<textarea id="message" name="message" required placeholder="Tell us more..." aria-required="true"></textarea>
						</div>

						<button type="submit" class="submit-btn">Send Message</button>
					</form>
				</section>
			</div>
		</section>
	</main>

	<script>
		const form = document.getElementById('contactForm');
const successMsg = document.getElementById('successMessage');
const errorMsg = document.getElementById('errorMessage');

form.addEventListener('submit', async function (e) {
e.preventDefault();

successMsg.style.display = 'none';
errorMsg.style.display = 'none';

const formData = new FormData(form);

try {
const response = await fetch(form.action, {
method: 'POST',
body: formData,
headers: {
'X-Requested-With': 'XMLHttpRequest'
}
});

const payload = await response.json().catch(() => null);

if (response.ok) {
successMsg.textContent = (payload && payload.message) || 'Submitted successfully.';
successMsg.style.display = 'block';
form.reset();

setTimeout(() => {
successMsg.style.display = 'none';
}, 5000);
} else {
errorMsg.textContent = (payload && payload.error) || 'Something went wrong. Please try again later.';
errorMsg.style.display = 'block';
}
} catch (error) {
errorMsg.textContent = 'Network error. Please check your connection and try again.';
errorMsg.style.display = 'block';
console.error('Error:', error);
}
});
	</script>
</body></html>
