{% extends '_layouts/master.html.twig' %}

{% block title %}Stock Details
{% endblock %}

{% block body %}
	<div class="container mx-auto px-6 py-8">
		<div class="max-w-4xl mx-auto">
			<div class="mb-6">
				<h1 class="text-3xl font-bold text-gray-800">Stock Details</h1>
				<p class="text-gray-600 mt-2">View stock movement information</p>
			</div>

			<div class="bg-white rounded-lg shadow-lg p-6">
				<div class="grid grid-cols-1 md:grid-cols-2 gap-4">
					<div class="bg-gray-50 rounded-lg px-4 py-3">
						<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Stock ID</p>
						<p class="text-base font-semibold text-gray-900 mt-1">{{ stock.id }}</p>
					</div>
					<div class="bg-gray-50 rounded-lg px-4 py-3">
						<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Product</p>
						<p class="text-base font-semibold text-gray-900 mt-1">{{ stock.productss ? stock.productss.name : 'No product linked' }}</p>
					</div>
					<div class="bg-gray-50 rounded-lg px-4 py-3">
						<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Quantity Change</p>
						<p class="text-base font-semibold mt-1">
							{% if stock.quantityChange is not null %}
								{% if stock.quantityChange > 0 %}
									<span class="text-green-600">+{{ stock.quantityChange }}</span>
								{% elseif stock.quantityChange < 0 %}
									<span class="text-red-600">{{ stock.quantityChange }}</span>
								{% else %}
									<span class="text-gray-700">0</span>
								{% endif %}
							{% else %}
								<span class="text-gray-700">-</span>
							{% endif %}
						</p>
					</div>
					<div class="bg-gray-50 rounded-lg px-4 py-3">
						<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Created At</p>
						<p class="text-base font-semibold text-gray-900 mt-1">{{ stock.createAt ? stock.createAt|date('F d, Y H:i:s') : '-' }}</p>
					</div>
					<div class="bg-gray-50 rounded-lg px-4 py-3 md:col-span-2">
						<p class="text-xs font-semibold text-gray-500 uppercase tracking-wide">Updated At</p>
						<p class="text-base font-semibold text-gray-900 mt-1">{{ stock.updateAt ? stock.updateAt|date('F d, Y H:i:s') : '-' }}</p>
					</div>
				</div>

				<div class="mt-6 bg-blue-50 border border-blue-100 rounded-lg px-4 py-4">
					<p class="text-xs font-semibold text-blue-700 uppercase tracking-wide mb-2">Stock Change Log</p>
					<p class="text-sm text-blue-900 break-words">{{ stock.stockChangeLog ?: '-' }}</p>
				</div>

				<div class="flex flex-wrap gap-3 mt-6 pt-6 border-t border-gray-200">
					<a href="{{ path('app_stocks_index') }}" class="bg-gray-300 hover:bg-gray-400 text-gray-800 font-semibold px-6 py-2 rounded-lg transition duration-200">
						Back to List
					</a>
					<a href="{{ path('app_stocks_edit', {'id': stock.id}) }}" class="bg-yellow-500 hover:bg-yellow-600 text-white font-semibold px-6 py-2 rounded-lg transition duration-200">
						Edit
					</a>
					{{ include('stocks/_delete_form.html.twig', {
                    button_class: 'bg-red-500 hover:bg-red-600 text-white font-semibold px-6 py-2 rounded-lg transition duration-200 border-0 cursor-pointer'
                }) }}
				</div>
			</div>
		</div>
	</div>
{% endblock %}
