{% extends '_layouts/master.html.twig' %}

{% block title %}Admin Dashboard
{% endblock %}

{% block body %}
	{% set adminShare = totalUsers > 0 ? ((totalAdmins / totalUsers) * 100) : 0 %}
	{% set staffShare = totalUsers > 0 ? ((totalStaff / totalUsers) * 100) : 0 %}
	{% set averageStockPerProduct = totalProducts > 0 ? (totalStockQuantity / totalProducts) : 0 %}

	<div class="space-y-8 pb-8">
		<section class="relative overflow-hidden rounded-3xl bg-gray-900 shadow-2xl">
			<div class="absolute inset-0 bg-gradient-to-br from-teal-600 via-cyan-500 to-amber-300 opacity-90"></div>
			<div class="absolute -left-12 top-10 h-40 w-40 rounded-full bg-white opacity-10 blur-3xl"></div>
			<div class="absolute right-0 top-0 h-64 w-64 rounded-full bg-orange-100 opacity-20 blur-3xl"></div>
			<div class="absolute bottom-0 right-1/4 h-48 w-48 rounded-full bg-blue-900 opacity-20 blur-3xl"></div>

			<div class="relative grid gap-8 px-6 py-8 lg:grid-cols-5 lg:px-10 lg:py-10">
				<div class="text-white lg:col-span-3">
					<span class="inline-flex items-center rounded-full border border-white border-opacity-25 bg-white bg-opacity-10 px-4 py-2 text-xs font-semibold uppercase tracking-widest">
						Admin dashboard
					</span>
					<h1 class="mt-6 max-w-3xl text-4xl font-black leading-tight lg:text-5xl">
						A brighter control center for your people, products, and revenue.
					</h1>
					<p class="mt-4 max-w-2xl text-base leading-7 text-white text-opacity-90 lg:text-lg">
						Track account growth, stock pressure, and completed-order income from a single screen that is easier to scan and easier to trust.
					</p>

					<div class="mt-8 grid gap-4 sm:grid-cols-3">
						<div class="rounded-2xl border border-white border-opacity-20 bg-black bg-opacity-20 p-4 backdrop-blur-sm">
							<p class="text-xs font-semibold uppercase tracking-widest text-white text-opacity-70">Admin share</p>
							<p class="mt-3 text-3xl font-black">{{ adminShare|number_format(0) }}%</p>
							<p class="mt-2 text-sm text-white text-opacity-75">of all registered accounts</p>
						</div>
						<div class="rounded-2xl border border-white border-opacity-20 bg-black bg-opacity-20 p-4 backdrop-blur-sm">
							<p class="text-xs font-semibold uppercase tracking-widest text-white text-opacity-70">Staff coverage</p>
							<p class="mt-3 text-3xl font-black">{{ staffShare|number_format(0) }}%</p>
							<p class="mt-2 text-sm text-white text-opacity-75">ready to support operations</p>
						</div>
						<div class="rounded-2xl border border-white border-opacity-20 bg-black bg-opacity-20 p-4 backdrop-blur-sm">
							<p class="text-xs font-semibold uppercase tracking-widest text-white text-opacity-70">Avg stock</p>
							<p class="mt-3 text-3xl font-black">{{ averageStockPerProduct|number_format(0) }}</p>
							<p class="mt-2 text-sm text-white text-opacity-75">units per product on hand</p>
						</div>
					</div>
				</div>

				<div class="lg:col-span-2">
					<div class="rounded-3xl bg-white p-6 shadow-2xl">
						<p class="text-sm font-semibold uppercase tracking-widest text-teal-600">Completed income</p>
						<h2 class="mt-4 text-4xl font-black text-gray-900 lg:text-5xl">PHP
							{{ totalCompletedIncome|number_format(2, '.', ',') }}</h2>
						<p class="mt-3 text-sm leading-6 text-gray-600"></p>

						<div class="mt-6 grid gap-4 sm:grid-cols-2">
							<div class="rounded-2xl bg-teal-50 p-4">
								<p class="text-xs font-semibold uppercase tracking-widest text-teal-700">Order volume</p>
								<p class="mt-2 text-3xl font-black text-gray-900">{{ totalOrders }}</p>
								<p class="mt-2 text-sm text-gray-600"></p>
							</div>
							<div class="rounded-2xl bg-amber-50 p-4">
								<p class="text-xs font-semibold uppercase tracking-widest text-amber-700">Stock on hand</p>
								<p class="mt-2 text-3xl font-black text-gray-900">{{ totalStockQuantity }}</p>
								<p class="mt-2 text-sm text-gray-600"></p>
							</div>
						</div>


					</div>
				</section>

				<section class="grid gap-5 md:grid-cols-2 xl:grid-cols-4">
					<div class="overflow-hidden rounded-3xl bg-white shadow-lg">
						<div class="h-1.5 bg-gradient-to-r from-cyan-500 to-blue-500"></div>
						<div class="p-6">
							<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Total users</p>
							<div class="mt-4 flex items-end justify-between gap-4">
								<h2 class="text-4xl font-black text-gray-900">{{ totalUsers }}</h2>
								<div class="rounded-2xl bg-cyan-50 p-3 text-cyan-700">
									<svg class="h-7 w-7" fill="currentColor" viewbox="0 0 24 24">
										<path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
									</svg>
								</div>
							</div>
							<p class="mt-3 text-sm leading-6 text-gray-600"></p>
						</div>
					</div>

					<div class="overflow-hidden rounded-3xl bg-white shadow-lg">
						<div class="h-1.5 bg-gradient-to-r from-rose-500 to-orange-400"></div>
						<div class="p-6">
							<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Administrators</p>
							<div class="mt-4 flex items-end justify-between gap-4">
								<h2 class="text-4xl font-black text-gray-900">{{ totalAdmins }}</h2>
								<div class="rounded-2xl bg-rose-50 p-3 text-rose-700">
									<svg class="h-7 w-7" fill="currentColor" viewbox="0 0 24 24">
										<path d="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4z"/>
									</svg>
								</div>
							</div>
							<p class="mt-3 text-sm leading-6 text-gray-600"></p>
						</div>
					</div>

					<div class="overflow-hidden rounded-3xl bg-white shadow-lg">
						<div class="h-1.5 bg-gradient-to-r from-emerald-500 to-teal-500"></div>
						<div class="p-6">
							<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Staff members</p>
							<div class="mt-4 flex items-end justify-between gap-4">
								<h2 class="text-4xl font-black text-gray-900">{{ totalStaff }}</h2>
								<div class="rounded-2xl bg-emerald-50 p-3 text-emerald-700">
									<svg class="h-7 w-7" fill="currentColor" viewbox="0 0 24 24">
										<path d="M16 11c1.66 0 2.99-1.34 2.99-3S17.66 5 16 5c-1.66 0-3 1.34-3 3s1.34 3 3 3zm-8 0c1.66 0 2.99-1.34 2.99-3S9.66 5 8 5C6.34 5 5 6.34 5 8s1.34 3 3 3zm0 2c-2.33 0-7 1.17-7 3.5V19h14v-2.5c0-2.33-4.67-3.5-7-3.5zm8 0c-.29 0-.62.02-.97.05 1.16.84 1.97 1.97 1.97 3.45V19h6v-2.5c0-2.33-4.67-3.5-7-3.5z"/>
									</svg>
								</div>
							</div>
							<p class="mt-3 text-sm leading-6 text-gray-600"></p>
						</div>
					</div>

					<div class="overflow-hidden rounded-3xl bg-white shadow-lg">
						<div class="h-1.5 bg-gradient-to-r from-amber-500 to-yellow-400"></div>
						<div class="p-6">
							<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Products</p>
							<div class="mt-4 flex items-end justify-between gap-4">
								<h2 class="text-4xl font-black text-gray-900">{{ totalProducts }}</h2>
								<div class="rounded-2xl bg-amber-50 p-3 text-amber-700">
									<svg class="h-7 w-7" fill="currentColor" viewbox="0 0 24 24">
										<path d="M19 3H5c-1.11 0-2 .9-2 2v14c0 1.1.89 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-7 14H7v-5h5v5zm7 0h-5v-5h5v5zm0-7h-5V7h5v3z"/>
									</svg>
								</div>
							</div>
							<p class="mt-3 text-sm leading-6 text-gray-600"></p>
						</div>
					</div>
				</section>

				<section class="grid gap-6 xl:grid-cols-5">
					<div class="xl:col-span-3">
						{% if petOfTheMonth %}
							<div class="relative overflow-hidden rounded-3xl bg-white shadow-xl">
								<div class="absolute inset-x-0 top-0 h-24 bg-gradient-to-r from-amber-400 via-orange-400 to-rose-400"></div>
								<div class="relative grid gap-6 px-6 pb-6 pt-8 md:grid-cols-2 md:px-8 md:pt-10">
									<div class="flex items-center justify-center md:justify-start">
										{% if petOfTheMonth.image %}
											<img src="{{ asset('uploads/pets/' ~ petOfTheMonth.image) }}" alt="{{ petOfTheMonth.name }}" class="h-64 w-64 rounded-3xl object-cover shadow-2xl ring-8 ring-white">
										{% else %}
											<div class="flex h-64 w-64 items-center justify-center rounded-3xl bg-gradient-to-br from-amber-100 to-orange-200 text-6xl font-black text-orange-500 shadow-2xl ring-8 ring-white">
												{{ petOfTheMonth.name|slice(0, 1)|upper }}
											</div>
										{% endif %}
									</div>

									<div class="flex flex-col justify-center">
										<p class="text-sm font-semibold uppercase tracking-widest text-amber-600">Pet of the month</p>
										<h2 class="mt-3 text-4xl font-black text-gray-900">{{ petOfTheMonth.name }}</h2>
										<p class="mt-3 text-base leading-7 text-gray-600"></p>

										<div class="mt-6 grid gap-3 sm:grid-cols-2">
											<div class="rounded-2xl bg-gray-50 p-4">
												<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Owner</p>
												<p class="mt-2 text-lg font-bold text-gray-900">{{ petOfTheMonth.owner ? petOfTheMonth.owner.fullName : 'No Owner' }}</p>
											</div>
											<div class="rounded-2xl bg-gray-50 p-4">
												<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Species</p>
												<p class="mt-2 text-lg font-bold text-gray-900">{{ petOfTheMonth.species }}</p>
											</div>
											<div class="rounded-2xl bg-gray-50 p-4">
												<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Breed</p>
												<p class="mt-2 text-lg font-bold text-gray-900">{{ petOfTheMonth.breed }}</p>
											</div>
											<div class="rounded-2xl bg-gray-50 p-4">
												<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Age</p>
												<p class="mt-2 text-lg font-bold text-gray-900">{{ petOfTheMonth.age }}
													years old</p>
											</div>
										</div>

										<a href="{{ path('app_pet_profile_management_show', {'id': petOfTheMonth.id}) }}" class="mt-6 inline-flex items-center justify-center rounded-2xl bg-gray-900 px-6 py-3 text-sm font-semibold text-white transition hover:bg-gray-800 md:w-auto">
											Open pet profile
										</a>
									</div>
								</div>
							</div>
						{% else %}
							<div class="relative overflow-hidden rounded-3xl bg-white p-8 shadow-xl">
								<div class="absolute inset-y-0 right-0 w-1/3 bg-gradient-to-b from-teal-50 to-cyan-100"></div>
								<div class="relative max-w-2xl">
									<p class="text-sm font-semibold uppercase tracking-widest text-cyan-600">Feature area</p>
									<h2 class="mt-3 text-3xl font-black text-gray-900">No featured pet selected yet.</h2>
									<p class="mt-4 text-base leading-7 text-gray-600"></p>
								</div>
							</div>
						{% endif %}
					</div>

					<div class="rounded-3xl bg-white p-6 shadow-xl xl:col-span-2">
						<p class="text-sm font-semibold uppercase tracking-widest text-gray-400">Operations focus</p>
						<h2 class="mt-3 text-3xl font-black text-gray-900">Team balance and inventory health.</h2>
						<p class="mt-3 text-sm leading-6 text-gray-600"></p>

						<div class="mt-6 space-y-5">
							<div>
								<div class="flex items-center justify-between text-sm font-semibold text-gray-700">
									<span>Admin accounts</span>
									<span>{{ adminShare|number_format(0) }}%</span>
								</div>
								<div class="mt-2 h-2.5 rounded-full bg-gray-100">
									<div class="h-2.5 rounded-full bg-gradient-to-r from-rose-500 to-orange-400" style="width: {{ adminShare|number_format(0, '.', '') }}%;"></div>
								</div>
							</div>

							<div>
								<div class="flex items-center justify-between text-sm font-semibold text-gray-700">
									<span>Staff coverage</span>
									<span>{{ staffShare|number_format(0) }}%</span>
								</div>
								<div class="mt-2 h-2.5 rounded-full bg-gray-100">
									<div class="h-2.5 rounded-full bg-gradient-to-r from-emerald-500 to-teal-500" style="width: {{ staffShare|number_format(0, '.', '') }}%;"></div>
								</div>
							</div>

							<div class="grid gap-4 sm:grid-cols-2">
								<div class="rounded-2xl bg-gray-50 p-4">
									<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Recent signups</p>
									<p class="mt-2 text-3xl font-black text-gray-900">{{ recentUsers|length }}</p>
									<p class="mt-2 text-sm text-gray-600"></p>
								</div>
								<div class="rounded-2xl bg-gray-50 p-4">
									<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Avg stock / product</p>
									<p class="mt-2 text-3xl font-black text-gray-900">{{ averageStockPerProduct|number_format(0) }}</p>
									<p class="mt-2 text-sm text-gray-600"></p>
								</div>
							</div>

							<div class="rounded-2xl bg-gradient-to-r from-gray-900 to-gray-800 p-5 text-white">
								<p class="text-xs font-semibold uppercase tracking-widest text-white text-opacity-60">Visibility note</p>
								<p class="mt-3 text-sm leading-6 text-white text-opacity-80"></p>
							</div>
						</div>
					</div>
				</section>

				<section class="rounded-3xl bg-white p-6 shadow-xl">
					<div class="flex flex-col gap-4 border-b border-gray-100 pb-6 sm:flex-row sm:items-end sm:justify-between">
						<div>
							<p class="text-sm font-semibold uppercase tracking-widest text-gray-400">Recent users</p>
							<h2 class="mt-2 text-3xl font-black text-gray-900">Latest registrations at a glance.</h2>
							<p class="mt-3 max-w-2xl text-sm leading-6 text-gray-600"></p>
						</div>
						<a href="{{ path('app_user_management_index') }}" class="inline-flex items-center justify-center rounded-2xl bg-gray-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-gray-800">
							Open user directory
						</a>
					</div>

					{% if recentUsers is not empty %}
						<div class="mt-6 grid gap-4 lg:grid-cols-2 xl:grid-cols-3">
							{% for user in recentUsers %}
								<div class="rounded-2xl border border-gray-100 bg-gray-50 p-5 transition hover:-translate-y-1 hover:shadow-lg">
									<div class="flex items-start justify-between gap-4">
										<div class="flex items-center gap-4">
											<div class="flex h-12 w-12 items-center justify-center rounded-2xl bg-gradient-to-br from-cyan-500 to-blue-600 text-lg font-black text-white shadow-md">
												{{ user.fullName ? user.fullName|slice(0, 1)|upper : 'U' }}
											</div>
											<div>
												<h3 class="text-lg font-bold text-gray-900">{{ user.fullName }}</h3>
												<p class="text-sm text-gray-500">{{ user.email }}</p>
											</div>
										</div>
										<div>
											{% if user.isAdmin() %}
												<span class="inline-flex rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700">Admin</span>
											{% elseif user.isStaff() %}
												<span class="inline-flex rounded-full bg-teal-100 px-3 py-1 text-xs font-semibold text-teal-700">Staff</span>
											{% else %}
												<span class="inline-flex rounded-full bg-gray-200 px-3 py-1 text-xs font-semibold text-gray-700">User</span>
											{% endif %}
										</div>
									</div>

									<div class="mt-5 grid grid-cols-2 gap-3">
										<div class="rounded-2xl bg-white p-4 shadow-sm">
											<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Created</p>
											<p class="mt-2 text-sm font-bold text-gray-900">{{ user.createdAt ? user.createdAt|date('M d, Y') : 'Unknown' }}</p>
										</div>
										<div class="rounded-2xl bg-white p-4 shadow-sm">
											<p class="text-xs font-semibold uppercase tracking-widest text-gray-400">Status</p>
											<p class="mt-2 text-sm font-bold text-gray-900">Active profile</p>
										</div>
									</div>
								</div>
							{% endfor %}
						</div>
					{% else %}
						<div class="mt-6 rounded-3xl border border-dashed border-gray-200 bg-gray-50 px-6 py-10 text-center">
							<p class="text-lg font-bold text-gray-900">No recent users found.</p>
							<p class="mt-2 text-sm text-gray-500"></p>
						</div>
					{% endif %}
				</section>

				<section class="grid gap-6 xl:grid-cols-5">
					<div class="rounded-3xl bg-white p-6 shadow-xl xl:col-span-3">
						<div class="flex flex-col gap-4 border-b border-gray-100 pb-6 sm:flex-row sm:items-end sm:justify-between">
							<div>
								<p class="text-sm font-semibold uppercase tracking-widest text-gray-400">Notifications</p>
								<h2 class="mt-2 text-3xl font-black text-gray-900">Recent system activity.</h2>
								<p class="mt-3 max-w-2xl text-sm leading-6 text-gray-600">Fresh activity from web and mobile actions now surfaces here so admins can spot account, order, and pet changes faster.</p>
							</div>
							<a href="{{ path('app_activity_log') }}" class="inline-flex items-center justify-center rounded-2xl bg-gray-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-gray-800">
								Open activity logs
							</a>
						</div>

						{% if recentActivityLogs is not empty %}
							<div class="mt-6 space-y-4">
								{% for log in recentActivityLogs %}
									{% set actionTone = log.action == 'DELETE' ? 'bg-rose-100 text-rose-700' : (log.action == 'UPDATE' ? 'bg-amber-100 text-amber-700' : (log.action == 'CREATE' ? 'bg-emerald-100 text-emerald-700' : 'bg-cyan-100 text-cyan-700')) %}
									<div class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
										<div class="flex flex-col gap-3 sm:flex-row sm:items-start sm:justify-between">
											<div>
												<div class="flex flex-wrap items-center gap-2">
													<span class="inline-flex rounded-full px-3 py-1 text-xs font-semibold {{ actionTone }}">{{ log.action }}</span>
													<span class="text-sm font-semibold text-gray-900">{{ log.username }}</span>
													<span class="inline-flex rounded-full bg-gray-200 px-2.5 py-1 text-[11px] font-semibold uppercase tracking-wider text-gray-600">{{ log.role|replace({'ROLE_': ''}) }}</span>
												</div>
												<p class="mt-2 text-sm text-gray-700">{{ log.targetData ?: 'Session activity recorded without a target record.' }}</p>
											</div>
											<div class="text-xs font-medium uppercase tracking-wider text-gray-400">
												{{ log.timestamp ? log.timestamp|date('M d, Y g:i A') : 'Just now' }}
											</div>
										</div>
									</div>
								{% endfor %}
							</div>
						{% else %}
							<div class="mt-6 rounded-3xl border border-dashed border-gray-200 bg-gray-50 px-6 py-10 text-center">
								<p class="text-lg font-bold text-gray-900">No notifications yet.</p>
								<p class="mt-2 text-sm text-gray-500">Recent system activity will appear here once your team starts using the dashboard or mobile app.</p>
							</div>
						{% endif %}
					</div>

					<div class="rounded-3xl bg-white p-6 shadow-xl xl:col-span-2">
						<div class="flex items-start justify-between gap-4">
							<div>
								<p class="text-sm font-semibold uppercase tracking-widest text-gray-400">Inbox</p>
								<h2 class="mt-2 text-3xl font-black text-gray-900">Contact alerts.</h2>
								<p class="mt-3 text-sm leading-6 text-gray-600">Keep an eye on saved-only messages and newly submitted inquiries from the website contact form.</p>
							</div>
							<a href="{{ path('app_admin_contact_messages_index') }}" class="inline-flex items-center justify-center rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm transition hover:bg-gray-50">
								Open inbox
							</a>
						</div>

						<div class="mt-6 grid gap-4 sm:grid-cols-2 xl:grid-cols-1 2xl:grid-cols-2">
							<div class="rounded-2xl bg-rose-50 p-4">
								<p class="text-xs font-semibold uppercase tracking-widest text-rose-700">Needs follow-up</p>
								<p class="mt-2 text-3xl font-black text-gray-900">{{ pendingContactMessages }}</p>
								<p class="mt-2 text-sm text-gray-600">Messages saved without confirmed email delivery.</p>
							</div>
							<div class="rounded-2xl bg-cyan-50 p-4">
								<p class="text-xs font-semibold uppercase tracking-widest text-cyan-700">Total inbox items</p>
								<p class="mt-2 text-3xl font-black text-gray-900">{{ totalContactMessages }}</p>
								<p class="mt-2 text-sm text-gray-600">All contact submissions stored for the admin team.</p>
							</div>
						</div>

						{% if recentContactMessages is not empty %}
							<div class="mt-6 space-y-3">
								{% for message in recentContactMessages %}
									{% set deliveryTone = message.emailSent ? 'bg-emerald-100 text-emerald-700' : 'bg-amber-100 text-amber-700' %}
									<div class="rounded-2xl border border-gray-100 bg-gray-50 p-4">
										<div class="flex items-start justify-between gap-3">
											<div class="min-w-0">
												<p class="truncate text-sm font-bold text-gray-900">{{ message.subject }}</p>
												<p class="mt-1 text-sm text-gray-600">{{ message.name }} · {{ message.email }}</p>
											</div>
											<span class="inline-flex rounded-full px-3 py-1 text-[11px] font-semibold uppercase tracking-wider {{ deliveryTone }}">{{ message.emailSent ? 'Delivered' : 'Saved only' }}</span>
										</div>
										<p class="mt-3 text-sm leading-6 text-gray-600">{{ message.message|length > 120 ? message.message|slice(0, 120) ~ '...' : message.message }}</p>
										<p class="mt-3 text-xs font-medium uppercase tracking-wider text-gray-400">{{ message.createdAt ? message.createdAt|date('M d, Y g:i A') : 'Just now' }}</p>
									</div>
								{% endfor %}
							</div>
						{% else %}
							<div class="mt-6 rounded-3xl border border-dashed border-gray-200 bg-gray-50 px-6 py-10 text-center">
								<p class="text-lg font-bold text-gray-900">No inbox alerts yet.</p>
								<p class="mt-2 text-sm text-gray-500">Website contact submissions will show up here.</p>
							</div>
						{% endif %}
					</div>
				</section>

			{# ─────────────────────────────────────────────────────────────────────
			   Pet Profiles Management
			   ───────────────────────────────────────────────────────────────────── #}
			<section class="space-y-4">
				<div class="flex items-center justify-between">
					<div>
						<h2 class="text-2xl font-black text-gray-900">Pet Profiles</h2>
						<p class="mt-1 text-sm text-gray-500">Select any pet as Pet of the Month from this panel.</p>
					</div>
					<a href="{{ path('app_pet_profile_management_index') }}" class="inline-flex items-center gap-2 rounded-2xl border border-gray-200 bg-white px-4 py-2 text-sm font-semibold text-gray-700 shadow-sm transition hover:bg-gray-50">
						Manage all pets →
					</a>
				</div>

				{% if allPets is defined and allPets|length > 0 %}
					<div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
						{% for pet in allPets %}
							<div class="overflow-hidden rounded-3xl bg-white shadow-lg {{ pet.isPetOfTheMonth ? 'ring-2 ring-amber-400' : '' }}">
								{% if pet.isPetOfTheMonth %}
									<div class="flex items-center gap-1.5 bg-amber-400 px-4 py-1.5">
										<span class="text-xs font-black uppercase tracking-widest text-white">⭐ Pet of the Month</span>
									</div>
								{% else %}
									<div class="h-1.5 bg-gradient-to-r from-teal-400 to-cyan-400"></div>
								{% endif %}

								<div class="p-5">
									<div class="flex items-center gap-4">
										{% if pet.image %}
											<img src="{{ asset('uploads/pets/' ~ pet.image) }}" alt="{{ pet.name }}" class="h-16 w-16 rounded-2xl object-cover shadow-md">
										{% else %}
											<div class="flex h-16 w-16 items-center justify-center rounded-2xl bg-gradient-to-br from-amber-100 to-orange-200 text-2xl font-black text-orange-500 shadow-md">
												{{ pet.name|slice(0, 1)|upper }}
											</div>
										{% endif %}
										<div class="min-w-0">
											<p class="truncate text-base font-bold text-gray-900">{{ pet.name }}</p>
											<p class="text-xs text-gray-500">{{ pet.species }}{% if pet.breed %} · {{ pet.breed }}{% endif %}</p>
											<p class="mt-0.5 text-xs text-gray-400">
												{{ pet.age ? pet.age ~ ' yrs old' : 'Age unknown' }}
											</p>
										</div>
									</div>

									{% if pet.owner %}
										<div class="mt-3 rounded-xl bg-gray-50 px-3 py-2">
											<p class="text-xs text-gray-400">Owner</p>
											<p class="text-sm font-semibold text-gray-700">{{ pet.owner.fullName }}</p>
										</div>
									{% endif %}

									<form method="POST" action="{{ path('app_pet_profile_toggle_pet_of_month', {'id': pet.id}) }}" class="mt-4">
										<input type="hidden" name="_token" value="{{ csrf_token('toggle-pet-of-month' ~ pet.id) }}">
										{% if pet.isPetOfTheMonth %}
											<button type="submit" class="w-full rounded-xl border border-amber-300 bg-amber-50 py-2 text-xs font-bold text-amber-700 transition hover:bg-amber-100">
												Remove from Pet of the Month
											</button>
										{% else %}
											<button type="submit" class="w-full rounded-xl bg-gray-900 py-2 text-xs font-bold text-white transition hover:bg-gray-700">
												Set as Pet of the Month
											</button>
										{% endif %}
									</form>
								</div>
							</div>
						{% endfor %}
					</div>
				{% else %}
					<div class="rounded-3xl border border-dashed border-gray-200 bg-gray-50 px-6 py-10 text-center">
						<p class="text-lg font-bold text-gray-900">No pet profiles yet.</p>
						<p class="mt-2 text-sm text-gray-500">Users will add their pets through the mobile app.</p>
					</div>
				{% endif %}
			</section>

		</div>

		{% endblock %}
