<email title="Verify Your Email Address">
    <body>
        <h1>Welcome {{ user.fullName }}!</h1>
        
        <p>Thank you for registering with Khriciadivino. To complete your registration, please verify your email address by clicking the button below:</p>
        
        <a href="{{ verification_url }}" style="display: inline-block; padding: 12px 24px; background-color: #3b82f6; color: white; text-decoration: none; border-radius: 4px; margin: 20px 0;">
            Verify Email Address
        </a>
        
        <p>Or copy and paste this link in your browser:</p>
        <p style="word-break: break-all;">{{ verification_url }}</p>
        
        <p>This verification link will expire in 24 hours.</p>
        
        <p>If you didn't create this account, please ignore this email.</p>
        
        <p>
            Best regards,<br>
            The Khriciadivino Team
        </p>
    </body>
</email>
