<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>{{ pet.name }}
			| Pet Details</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@500;600;700;800;900&family=Nunito:wght@400;500;600;700&display=swap" rel="stylesheet">
	</head>
	<body style="margin: 0; font-family: 'Nunito', sans-serif; background: #f4f5f9; color: #171a21;">
		<main style="max-width: 1000px; margin: 0 auto; padding: 2rem 1rem 3rem;">
			<a href="{{ path('app_landing') }}#gallery" style="display: inline-block; margin-bottom: 1rem; text-decoration: none; color: #154b7f; font-family: 'Montserrat', sans-serif; font-weight: 700;">&larr; Back to Gallery</a>

			<section style="background: #ffffff; border-radius: 16px; padding: 1.5rem; box-shadow: 0 10px 24px rgba(8, 20, 36, 0.08);">
				<div style="display: grid; grid-template-columns: 300px 1fr; gap: 1.5rem; align-items: start;">
					<div style="background: #e8f0f8; border-radius: 12px; overflow: hidden;">
						<img src="{{ asset('images/' ~ pet.image) }}" alt="{{ pet.name }}" style="width: 100%; height: 100%; display: block; object-fit: cover;">
					</div>

					<div>
						<h1 style="margin: 0; font-family: 'Montserrat', sans-serif; font-size: clamp(1.6rem, 3vw, 2.2rem);">{{ pet.name }}</h1>
						<p style="margin: 0.4rem 0 1rem; color: #2f679d; font-family: 'Montserrat', sans-serif; font-weight: 700;">{{ pet.title }}</p>

						<p style="margin: 0.4rem 0; font-size: 1rem;">
							<strong>Type:</strong>
							{{ pet.type }}</p>
						<p style="margin: 0.4rem 0; font-size: 1rem;">
							<strong>Pet of the Month:</strong>
							{{ pet.petOfMonthDate }}</p>
						<p style="margin: 1rem 0 0; line-height: 1.7; color: #50555f;">{{ pet.description }}</p>
					</div>
				</div>
			</section>
		</main>
	</body>
</html>
